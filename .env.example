# Testmo MCP Server Configuration

# Your Testmo instance URL (without trailing slash)
TESTMO_URL=https://your-instance.testmo.net

# Your Testmo API key (get this from your Testmo account settings)
# Navigate to: Settings > API Keys > Create API Key
TESTMO_API_KEY=your_api_key_here

# The project ID to use for the MCP server if you want to lock the server to a specific project
# PROJECT_ID=123